# ─────────────────────────────────────────────────────────────
# Starlink Courier & Cargo Service — environment configuration
# Copy to .env.local and fill in values to take the site live.
# ─────────────────────────────────────────────────────────────

# ── Site identity ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://www.starlinkcourier.com"
NEXT_PUBLIC_BRAND_NAME="Starlink Courier & Cargo Service"
NEXT_PUBLIC_BRAND_SHORT="Starlink"
NEXT_PUBLIC_BRAND_EYEBROW="Courier & Cargo"
NEXT_PUBLIC_BRAND_TAGLINE="Reliable courier and cargo, delivered worldwide."
NEXT_PUBLIC_BRAND_DESCRIPTION="Trusted courier and cargo service connecting Pakistan to the world — air freight, sea cargo, DDP delivery, and door-to-door parcel handling without surprises."

# ── Contact ────────────────────────────────────────────────────
NEXT_PUBLIC_EMAIL="hello@starlinkcourier.com"
NEXT_PUBLIC_PHONE_PRIMARY="+92 332 6135002"
NEXT_PUBLIC_PHONE_SECONDARY="+92 332 8884396"
NEXT_PUBLIC_PHONE_UK="+44 7404 654725"

# ── WhatsApp (digits only, with country code, no + or spaces) ─
NEXT_PUBLIC_WHATSAPP_NUMBER="923326135002"
NEXT_PUBLIC_WHATSAPP_NUMBER_UK="447404654725"

# ── Address & location ─────────────────────────────────────────
NEXT_PUBLIC_ADDRESS="Office 64, opposite DMO Office, Workshop Road, Mughalpura, Lahore, Pakistan"
NEXT_PUBLIC_ADDRESS_SHORT="Lahore, Pakistan"
NEXT_PUBLIC_MAP_LAT="31.5666561"
NEXT_PUBLIC_MAP_LNG="74.3654366"

# ── Promo banner ───────────────────────────────────────────────
NEXT_PUBLIC_PROMO_TEXT="Introducing DDP shipping to the UK, USA & Europe — duty handled, no surprises."

# ── Currency (display) ─────────────────────────────────────────
NEXT_PUBLIC_CURRENCY_SYMBOL="₨"
NEXT_PUBLIC_CURRENCY_PER_UNIT="kg"

# ── Supabase (required for /track and /admin) ──────────────────
# Create a project at https://supabase.com and paste the public URL + anon key.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Meta / Facebook Pixel + Conversions API (optional) ─────────
NEXT_PUBLIC_META_PIXEL_ID=""
META_PIXEL_ID=""
META_ACCESS_TOKEN=""
META_GRAPH_VERSION="v20.0"
META_TEST_EVENT_CODE=""
